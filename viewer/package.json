{
  "name": "viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -b --noEmit",
    "ci": "bun run format && bun run check && bun run typecheck",
    "preview": "vite preview"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^1.9.3",
    "@rolldown/plugin-babel": "^0.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": "biome format --write",
    "*.{ts,tsx}": [
      "biome check --apply",
      "tsc --noEmit"
    ]
  }
}